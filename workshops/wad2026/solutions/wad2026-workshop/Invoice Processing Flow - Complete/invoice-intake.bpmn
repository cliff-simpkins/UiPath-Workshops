    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="xy-edge__switchNameMatchOutcomecase-default-2-discrepancyInvestigatorAgentinput" name="Review (High)" sourceRef="switchNameMatchOutcome" targetRef="discrepancyInvestigatorAgent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.vendorResearchAgent1.output.flag === "review" &amp;&amp; vars.vendorResearchAgent1.output.confidence === "high"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="xy-edge__switchNameMatchOutcomecase-mqzug2zf-7tsck-end1input" name="Reject" sourceRef="switchNameMatchOutcome" targetRef="end1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.vendorResearchAgent1.output.flag === "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="xy-edge__switchNameMatchOutcomedefault-end1input" sourceRef="switchNameMatchOutcome" targetRef="end1" />
    <bpmn:sequenceFlow id="xy-edge__switchNameMatchOutcomecase-mqzuq2jq-a95w5-end1input" name="Review (Low)" sourceRef="switchNameMatchOutcome" targetRef="end1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.vendorResearchAgent1.output.flag === "review"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
