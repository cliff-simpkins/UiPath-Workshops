    <bpmn:scriptTask id="mockFileData" name="Mock - Sets invoice data based on filename" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="mockFileData.output" type="object" source="=result.response" var="mockFileData.output" />
          <uipath:output name="mockFileData.error" type="object" source="=Error" var="mockFileData.error" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:output name="data_invoice" type="string" source="=js:vars.mockFileData.output" var="data_invoice" custom="true" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:script><![CDATA[const filename = (vars.downloadInvoice.output?.FullName ?? '').toLowerCase();

const FIXTURES = {
  'case-1-alphabet': {
    vendor:    { vendor_name: "Alphabet", vendor_address: "1600 AMPHITHEATRE PARKWAY MOUNTAIN VIEW, CA" },
    invoice:   { invoice_number: "ALPH-2026-04812", invoice_date: "2026-05-15", due_date: "2026-06-14", PO_reference: "PO-2026-09421", subtotal: "900.00 USD", tax: null, freight: null, total: "900.00 USD" },
    lineItems: [
      { description: "Google Workspace Business Plus - monthly seat license GWS-BIZ-PLUS", quantity: "50.00", unit_price: "18.00 USD", extended_amount: "900.00 USD" }
    ]
  },
  'case-2-apex': {
    vendor:    { vendor_name: "Apex Global LLC", vendor_address: "P.O. Box 4421, Reno, NV 89505" },
    invoice:   { invoice_number: "AG-INV-7714", invoice_date: "2026-05-18", due_date: "2026-06-17", PO_reference: "PO-2026-12035", subtotal: "1260.00 USD", tax: "100.80 USD", freight: "35.00 USD", total: "1395.80 USD" },
    lineItems: [
      { description: "Stainless Steel Ball Bearing 6204-2RS BEAR-6204-SS", quantity: "200.00", unit_price: "4.75 USD",  extended_amount: "950.00 USD" },
      { description: "M8 x 40mm Hex Head Bolt, Grade 8 BLT-M8X40-HD",     quantity: "500.00", unit_price: "0.62 USD",  extended_amount: "310.00 USD" }
    ]
  },
  'case-3-freight': {
    vendor:    { vendor_name: "Stratton Office Supply Co.", vendor_address: "445 Industrial Blvd, Austin, TX 78744" },
    invoice:   { invoice_number: "SOS-2026-3389", invoice_date: "2026-05-20", due_date: "2026-06-19", PO_reference: "PO-2026-10872", subtotal: "7170.00 USD", tax: "573.60 USD", freight: "150.00 USD", total: "7893.60 USD" },
    lineItems: [
      { description: "Dell Latitude 7440 - 14\" laptop, i7, 16GB RAM, 512GB SSD", quantity: "3.00", unit_price: "1450.00 USD", extended_amount: "4350.00 USD" },
      { description: "Dell UltraSharp U2723QE 27\" 4K monitor",                   quantity: "3.00", unit_price: "620.00 USD",  extended_amount: "1860.00 USD" },
      { description: "Dell Thunderbolt Dock WD22TB4",                             quantity: "3.00", unit_price: "320.00 USD",  extended_amount: "960.00 USD"  }
    ]
  },
  'case-4-perfect': {
    vendor:    { vendor_name: "Helix Marketing", vendor_address: "211 W 14th St Suite 8B New York, NY 10011" },
    invoice:   { invoice_number: "HMG-INV-2104", invoice_date: "2026-05-22", due_date: "2026-06-21", PO_reference: "PO-2026-11203", subtotal: "11700.00 USD", tax: null, freight: null, total: "11700.00 USD" },
    lineItems: [
      { description: "Brand identity design package",         quantity: "1.00", unit_price: "8500.00 USD", extended_amount: "8500.00 USD" },
      { description: "Website copywriting - up to 10 pages", quantity: "1.00", unit_price: "3200.00 USD", extended_amount: "3200.00 USD" }
    ]
  },
  'case-5-partial': {
    vendor:    { vendor_name: "NORTHWINDINDUSTRIAL", vendor_address: "SUPPLY CO. SEATTLE DISTRIBUTION" },
    invoice:   { invoice_number: "NWI-2026-5621", invoice_date: "2026-05-25", due_date: "2026-06-24", PO_reference: "PO-2026-11587", subtotal: "1662.50 USD", tax: "133.00 USD", freight: "25.00 USD", total: "1820.50 USD" },
    lineItems: [
      { description: "Nitrile examination gloves, large, box of 100", quantity: "40.00", unit_price: "12.50 USD", extended_amount: "500.00 USD"  },
      { description: "70% IPA cleaning wipes, 100-count canister",    quantity: "30.00", unit_price: "8.75 USD",  extended_amount: "262.50 USD" },
      { description: "3M N95 respirator mask, box of 20",             quantity: "25.00", unit_price: "36.00 USD", extended_amount: "900.00 USD"  }
    ]
  }
};

const match = Object.entries(FIXTURES).find(([key]) => filename.includes(key));

if (!match) {
  throw new Error(`IXP standin: no fixture for "${filename}". Add an entry to FIXTURES.`);
}

return match[1];
]]></bpmn:script>
    </bpmn:scriptTask>
