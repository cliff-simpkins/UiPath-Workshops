            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vendorName_invoice":{"type":"string"},"scriptPrepareBrief__output":{"type":"object"},"discrepancyInvestigatorAgent__output":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
