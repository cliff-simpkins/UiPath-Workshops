    <bpmn:sequenceFlow id="xy-edge__decisionVendorNamefalse-vendorResearchAgent1input" name="False" sourceRef="decisionVendorName" targetRef="vendorResearchAgent1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:!(vars.scriptGetInvoice.output.vendor.vendor_name === vars.queryPoData.output[0].vendorName)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
