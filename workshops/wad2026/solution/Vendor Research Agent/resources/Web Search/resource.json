        "type": "object",
        "properties": {
          "title": {
            "title": "Result title",
            "type": "string",
            "description": "The title of a search result item."
          },
          "snippet": {
            "title": "Result snippet",
            "type": "string",
            "description": "A brief summary or excerpt of a search result item."
          },
          "url": {
            "title": "Result url",
            "type": "string",
            "description": "The web address of the search result."
          }
        }
      }
    }
