    {
      "id": "scriptExtractInvoiceResults",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Script - Extract Invoice Data",
        "subLabel": "Extract invoice information",
        "icon": "code"
      },
      "inputs": {
        "script": {
          "type": "literal",
          "expression": "const doc = $vars.documentExtraction1.output?.ExtractionResult?.ResultsDocument;\r\nconst fields = doc?.Fields || [];\r\n\r\n// Helper: pull a simple component's value\r\nconst readComponent = (comp) => {\r\n  if (!comp || comp.IsMissing || !comp.Values || comp.Values.length === 0) {\r\n    return null;\r\n  }\r\n  return comp.Values[0]?.Value ?? null;\r\n};\r\n\r\n// Helper: find a top-level field by FieldId\r\nconst findField = (fieldId) => fields.find(f => f?.FieldId === fieldId);\r\n\r\n// Helper: sanitize field names (replace spaces with underscores)\r\nconst sanitizeFieldName = (fieldName) => fieldName?.replace(/\\s+/g, '_') || '';\r\n\r\n// Vendor fields now live inside the Invoice group, not a separate group\r\nconst VENDOR_FIELDS = new Set(['vendor_name', 'vendor_address']);\r\n\r\n// Initialize result object\r\nconst result = { invoice: {}, vendor: {}, lineItems: [] };\r\n\r\n// --- Invoice group (single instance) ---\r\n// Contains both invoice-level fields and vendor fields\r\nconst invoice = findField(\"Default.Invoice\");\r\nif (invoice && !invoice.IsMissing && invoice.Values?.length) {\r\n  for (const comp of invoice.Values[0]?.Components || []) {\r\n    const key = sanitizeFieldName(comp?.FieldName);\r\n    if (VENDOR_FIELDS.has(comp?.FieldName)) {\r\n      result.vendor[key] = readComponent(comp);\r\n    } else {\r\n      result.invoice[key] = readComponent(comp);\r\n    }\r\n  }\r\n}\r\n\r\n// --- Line Items group (repeating: one entry per row) ---\r\nconst lineItems = findField(\"Default.Invoice>line_items\");\r\nif (lineItems && !lineItems.IsMissing && lineItems.Values?.length) {\r\n  for (const row of lineItems.Values || []) {\r\n    const item = {};\r\n    for (const comp of row?.Components || []) {\r\n      item[sanitizeFieldName(comp?.FieldName)] = readComponent(comp);\r\n    }\r\n    result.lineItems.push(item);\r\n  }\r\n}\r\n\r\n// Remove spaces from the keys in the result object recursively\r\nconst sanitizeKeys = (obj) => {\r\n  if (Array.isArray(obj)) {\r\n    return obj.map(sanitizeKeys);\r\n  } else if (obj && typeof obj === 'object') {\r\n    return Object.fromEntries(\r\n      Object.entries(obj).map(([key, value]) => [sanitizeFieldName(key), sanitizeKeys(value)])\r\n    );\r\n  }\r\n  return obj;\r\n};\r\n\r\nreturn sanitizeKeys(result);",
          "fieldType": "string"
        }
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
