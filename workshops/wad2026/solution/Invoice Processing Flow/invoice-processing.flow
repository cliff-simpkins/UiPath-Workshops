      "projectId": "3500a098-9cc6-4e6f-8c44-c30741d4199c",
      "model": {
        "type": "bpmn:ServiceTask",
        "serviceType": "Orchestrator.StartAgentJob",
        "version": "v2",
        "section": "In this solution",
        "skipBindingsReference": true,
        "bindings": {
          "resource": "process",
          "resourceSubType": "Agent",
          "resourceKey": "3677af20-722c-4a3e-a46e-9c322013f715",
          "orchestratorType": "agent",
          "values": [
            {
              "name": "name",
              "propertyAttribute": "name",
              "default": "Discrepancy Investigator Agent"
            },
            {
              "name": "folderPath",
              "propertyAttribute": "folderPath",
              "default": ""
            }
          ]
        },
        "projectId": "3500a098-9cc6-4e6f-8c44-c30741d4199c",
        "projectName": "Discrepancy Investigator Agent",
        "context": [
          {
            "name": "name",
            "type": "string",
            "value": "<bindings.name>"
          },
          {
            "name": "folderPath",
            "type": "string",
            "value": "<bindings.folderPath>"
          },
          {
            "name": "_label",
            "type": "string",
            "value": "Discrepancy Investigator Agent"
          }
        ]
      },
      "form": {
        "id": "activity-properties",
        "title": "Agent",
        "sections": [
          {
            "id": "inputs",
            "title": "Inputs",
            "collapsible": true,
            "defaultExpanded": true,
            "fields": [
              {
                "name": "inputs.invoiceData",
                "type": "text",
                "label": "invoiceData"
              },
              {
                "name": "inputs.poData",
                "type": "text",
                "label": "poData"
              }
            ]
          }
        ]
      },
      "inputDefinition": {
        "invoiceData": "text",
        "poData": "text"
      },
      "inputDefaults": {
        "invoiceData": "",
        "poData": ""
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "source": "=this",
          "var": "output",
          "schema": {
            "type": "object",
            "properties": {
              "discrepancies": {
                "type": "array",
                "description": "Each discrepancy found between invoice and PO.",
                "items": {
                  "type": "object",
                  "required": [
                    "field",
                    "severity",
                    "explanation",
                    "evidence"
                  ],
                  "properties": {
                    "field": {
                      "type": "string",
                      "description": "Name of the discrepant field, e.g. totalAmount, lineItems[2].unitPrice, vendorName."
                    },
                    "invoiceValue": {
                      "description": "Value of the field on the invoice. Use the natural JSON type (string, number, boolean)."
                    },
                    "poValue": {
                      "description": "Value of the field on the PO."
                    },
                    "deltaAmount": {
                      "type": "number",
                      "description": "Absolute USD difference where applicable. 0 for non-monetary fields."
                    },
                    "severity": {
                      "type": "string",
                      "description": "minor: note but does not change recommendation on its own. major: needs human review. critical: blocks payment.",
                      "enum": [
                        "minor",
                        "major",
                        "critical"
                      ]
                    },
                    "explanation": {
                      "type": "string",
                      "description": "Why this is a discrepancy and what the implication is."
                    },
                    "evidence": {
                      "type": "string",
                      "description": "Contract clause, catalog entry, step-by-step arithmetic, or 'direct field comparison'. Required for every item."
                    }
                  }
                }
              },
              "totalAmountDelta": {
                "type": "number",
                "description": "Absolute USD difference between invoice totalAmount and PO totalAmount. 0 when totals match. Used to apply the USD 100 escalation threshold."
              },
              "recommendation": {
                "type": "string",
                "description": "Recommended downstream action.",
                "enum": [
                  "approve",
                  "escalate",
                  "reject"
                ]
              },
              "escalated": {
                "type": "boolean",
                "description": "True if and only if the Human Review escalation was actually triggered during this run."
              },
              "reasoning": {
                "type": "string",
                "description": "2-4 sentence explanation of why this recommendation was reached, citing the primary discrepancy and any contract evidence retrieved."
              }
            }
          }
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "debug": {
        "runtime": "bpmnEngine"
      }
    },
