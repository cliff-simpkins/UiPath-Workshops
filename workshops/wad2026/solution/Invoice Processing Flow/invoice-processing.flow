      "form": {
        "id": "activity-properties",
        "title": "Agent",
        "sections": [
          {
            "id": "inputs",
            "title": "Inputs",
            "collapsible": true,
            "defaultExpanded": true,
            "fields": [
              {
                "name": "inputs.invoiceVendorName",
                "type": "text",
                "label": "invoiceVendorName"
              },
              {
                "name": "inputs.poVendorName",
                "type": "text",
                "label": "poVendorName"
              }
            ]
          }
        ]
      },
      "inputDefinition": {
        "invoiceVendorName": "text",
        "poVendorName": "text"
      },
      "inputDefaults": {
        "invoiceVendorName": "",
        "poVendorName": ""
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "source": "=this",
          "var": "output",
          "schema": {
            "type": "object",
            "properties": {
              "relationship": {
                "type": "string",
                "description": "Relationship between the invoice vendor and the PO vendor. same_entity: different legal names, same company (DBA, abbreviation, translation, with/without suffix). parent_subsidiary: one is the legal parent of the other. affiliate: both share a common parent or are under common control. acquired_or_merged: one acquired or merged with the other. predecessor_successor: rebrand or legal name change. unrelated: no documented relationship. look_alike_or_typosquat: deliberate fraudulent look-alike. unknown: insufficient information.",
                "enum": [
                  "same_entity",
                  "parent_subsidiary",
                  "affiliate",
                  "acquired_or_merged",
                  "predecessor_successor",
                  "unrelated",
                  "look_alike_or_typosquat",
                  "unknown"
                ]
              },
              "flag": {
                "type": "string",
                "description": "Recommended downstream action. approve: legitimate relationship verified with high confidence. review: ambiguous, needs human review. reject: likely fraud or unrelated entity.",
                "enum": [
                  "approve",
                  "review",
                  "reject"
                ]
              },
              "confidence": {
                "type": "string",
                "description": "Confidence in the relationship classification, based on quality and corroboration of sources.",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "reasoning": {
                "type": "string",
                "description": "Concise explanation of how the relationship was determined. Reference specific corporate facts (acquisition year, parent/subsidiary structure, rebrand) discovered via web search."
              },
              "sources": {
                "type": "array",
                "description": "URLs of authoritative sources used to determine the relationship (SEC filings, official corporate pages, press releases, reputable news). At least 1 if relationship != unknown.",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "debug": {
        "runtime": "bpmnEngine"
      }
    },
    {
      "nodeType": "core.logic.switch",
      "version": "1.1",
      "category": "control-flow",
      "description": "Route to one of many branches by condition",
      "tags": [
        "control-flow",
        "switch",
        "case",
        "when"
      ],
      "sortOrder": 20,
      "display": {
        "label": "Switch",
        "icon": "between-horizontal-start"
      },
      "handleConfiguration": [
        {
          "position": "left",
          "handles": [
            {
              "id": "input",
              "type": "target",
              "handleType": "input"
            }
          ],
          "visible": true
        },
        {
          "position": "right",
          "handles": [
            {
              "id": "case-{item.id}",
              "type": "source",
              "handleType": "output",
              "label": "{item.label || 'Case ' + (index + 1)}",
              "repeat": "inputs.cases"
            },
            {
              "id": "default",
              "type": "source",
              "handleType": "output",
              "label": "Default"
            }
          ],
          "visible": true
        }
      ],
      "debug": {
        "runtime": "clientScript"
      },
      "model": {
        "type": "bpmn:ExclusiveGateway"
      },
      "inputDefinition": {
        "type": "object",
        "properties": {
          "cases": {
            "type": "array",
            "minItems": 1,
            "errorMessage": "At least one case is required",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "expression": {
                  "type": "string",
                  "minLength": 1,
                  "errorMessage": "A condition expression is required"
                }
              },
              "required": [
                "expression"
              ]
            }
          }
        },
        "required": [
          "cases"
        ]
      },
      "outputDefinition": {
        "matchedCase": {
          "type": "string",
          "description": "The label of the matched case",
          "var": "matchedCase"
        },
        "matchedCaseId": {
          "type": "string",
          "description": "The ID of the matched case (\"default\" for the default branch)",
          "var": "matchedCaseId"
        }
      },
      "inputDefaults": {
        "cases": [
          {
            "id": "default-1",
            "label": "Case 1",
            "expression": ""
          },
          {
            "id": "default-2",
            "label": "Case 2",
            "expression": ""
          }
        ]
      },
      "form": {
        "id": "switch-properties",
        "title": "Switch configuration",
        "sections": [
          {
            "id": "cases",
            "title": "Cases",
            "description": "Each case is evaluated in order. The first condition that returns true is taken.",
            "collapsible": true,
            "defaultExpanded": true,
            "fields": [
              {
                "name": "inputs.cases",
                "type": "custom",
                "label": "Switch cases",
                "component": "case-list-editor",
                "componentProps": {
                  "minCases": 1,
                  "maxCases": 10,
                  "expressionPlaceholder": "e.g., $vars.value <= 30",
                  "expressionValidationFields": [
                    {
                      "subPath": "expression",
                      "validationMode": "expression",
                      "expectedType": "boolean"
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "runtimeConstraints": {
        "exclude": [
          "api-function"
        ]
      }
    },
