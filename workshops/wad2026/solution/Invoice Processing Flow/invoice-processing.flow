    {
      "id": "decision1",
      "type": "core.logic.decision",
      "typeVersion": "1.0",
      "display": {
        "label": "Decision - Vendor Match",
        "subLabel": "Validate invoice vendor matches PO vendor",
        "icon": "trending-up-down"
      },
      "inputs": {
        "trueLabel": "True",
        "falseLabel": "False",
        "expression": {
          "type": "jsExpression",
          "expression": "$vars.scriptExtractInvoiceResults.output.vendor.vendor_name === $vars.queryEntityRecords1.output[0].vendorName",
          "fieldType": "boolean"
        }
      }
    },
    {
      "id": "discrepancyInvestigatorAgent1",
      "type": "uipath.core.agent.3677af20-722c-4a3e-a46e-9c322013f715",
      "typeVersion": "1.0.0",
      "display": {
        "label": "Discrepancy Investigator Agent",
        "subLabel": "",
        "icon": "autonomous-agent"
      },
      "inputs": {
        "invoiceData": {
          "type": "jsExpression",
          "expression": "JSON.stringify($vars.scriptExtractInvoiceResults.output)",
          "fieldType": "string"
        },
        "poData": {
          "type": "jsExpression",
          "expression": "JSON.stringify($vars.queryEntityRecords1.output)",
          "fieldType": "string"
        }
      },
      "outputs": {
        "output": {
          "type": "object",
          "source": "=this",
          "var": "output",
          "schema": {
            "type": "object",
            "properties": {
              "discrepancies": {
                "type": "array",
                "description": "Each discrepancy found between invoice and PO.",
                "items": {
                  "type": "object",
                  "required": [
                    "field",
                    "severity",
                    "explanation",
                    "evidence"
                  ],
                  "properties": {
                    "field": {
                      "type": "string",
                      "description": "Name of the discrepant field, e.g. totalAmount, lineItems[2].unitPrice, vendorName."
                    },
                    "invoiceValue": {
                      "description": "Value of the field on the invoice. Use the natural JSON type (string, number, boolean)."
                    },
                    "poValue": {
                      "description": "Value of the field on the PO."
                    },
                    "deltaAmount": {
                      "type": "number",
                      "description": "Absolute USD difference where applicable. 0 for non-monetary fields."
                    },
                    "severity": {
                      "type": "string",
                      "description": "minor: note but does not change recommendation on its own. major: needs human review. critical: blocks payment.",
                      "enum": [
                        "minor",
                        "major",
                        "critical"
                      ]
                    },
                    "explanation": {
                      "type": "string",
                      "description": "Why this is a discrepancy and what the implication is."
                    },
                    "evidence": {
                      "type": "string",
                      "description": "Contract clause, catalog entry, step-by-step arithmetic, or 'direct field comparison'. Required for every item."
                    }
                  }
                }
              },
              "totalAmountDelta": {
                "type": "number",
                "description": "Absolute USD difference between invoice totalAmount and PO totalAmount. 0 when totals match. Used to apply the USD 100 escalation threshold."
              },
              "recommendation": {
                "type": "string",
                "description": "Recommended downstream action.",
                "enum": [
                  "approve",
                  "escalate",
                  "reject"
                ]
              },
              "escalated": {
                "type": "boolean",
                "description": "True if and only if the Human Review escalation was actually triggered during this run."
              },
              "reasoning": {
                "type": "string",
                "description": "2-4 sentence explanation of why this recommendation was reached, citing the primary discrepancy and any contract evidence retrieved."
              }
            }
          }
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "decisionHumanReview",
      "type": "core.logic.decision",
      "typeVersion": "1.0",
      "display": {
        "label": "Decision - Human Review Required",
        "icon": "trending-up-down"
      },
      "inputs": {
        "trueLabel": "True",
        "falseLabel": "False",
        "expression": {
          "type": "jsExpression",
          "expression": "$vars.discrepancyInvestigatorAgent1.output.escalated",
          "fieldType": "boolean"
        }
      }
    },
    {
      "id": "scriptHitlStandin",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Script - Human Approval Placeholder",
        "subLabel": "",
        "icon": "code"
      },
      "inputs": {
        "script": {
          "type": "literal",
          "expression": "const hitlDecision = \"approved\"\r\n\r\nreturn hitlDecision;",
          "fieldType": "string"
        }
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
