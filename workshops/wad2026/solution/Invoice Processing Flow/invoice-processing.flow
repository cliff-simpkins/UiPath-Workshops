    {
      "id": "script1",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Script- Email Brief",
        "subLabel": "",
        "icon": "code"
      },
      "inputs": {
        "script": {
          "type": "literal",
          "expression": "const agent = $vars.discrepancyInvestigatorAgent1.output;\r\n\r\nlet briefing = `Invoice review findings:\r\n- Recommendation: ${agent.recommendation}\r\n- Summary: ${agent.reasoning}\r\n- Total variance: $${agent.totalAmountDelta}\r\n`;\r\n\r\nif (agent.escalated) {\r\n  const decision = $vars.scriptHitlStandin.output;\r\n  briefing += `- Human review decision: ${decision}\r\n\r\nThis invoice required human review. Write the email reflecting that it has been \r\nreviewed and the outcome was: ${decision}.`;\r\n} else {\r\n  briefing += `\r\nThis invoice did not require escalation. Write as a straightforward approval.`;\r\n}\r\n\r\nreturn { briefing };",
          "fieldType": "string"
        }
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
