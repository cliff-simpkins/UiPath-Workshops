    <bpmn:scriptTask id="scriptExtractInvoiceResults" name="Script - Extract Invoice Data" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:context>
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"vars":{"type":"object"},"metadata":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"vars":"=vars","metadata":"=metadata"}]]></uipath:input>
          <uipath:output name="scriptExtractInvoiceResults.output" type="object" source="=result.response" var="scriptExtractInvoiceResults.output" />
          <uipath:output name="scriptExtractInvoiceResults.error" type="object" source="=Error" var="scriptExtractInvoiceResults.error" />
        </uipath:mapping>
        <uipath:scriptVersion value="v3" />
      </bpmn:extensionElements>
      <bpmn:incoming>edge_documentExtraction1-success-core.action.script-1781129512738-input</bpmn:incoming>
      <bpmn:outgoing>edge_script1-success-uipath.connector.uipath-uipath-dataservice.query-entity-records-1781129771983-input</bpmn:outgoing>
      <bpmn:script><![CDATA[const doc = vars.documentExtraction1.output?.ExtractionResult?.ResultsDocument;
const fields = doc?.Fields || [];

// Helper: pull a simple component's value
const readComponent = (comp) => {
  if (!comp || comp.IsMissing || !comp.Values || comp.Values.length === 0) {
    return null;
  }
  return comp.Values[0]?.Value ?? null;
};

// Helper: find a top-level field by FieldId
const findField = (fieldId) => fields.find(f => f?.FieldId === fieldId);

// Helper: sanitize field names (replace spaces with underscores)
const sanitizeFieldName = (fieldName) => fieldName?.replace(/\s+/g, '_') || '';

// Vendor fields now live inside the Invoice group, not a separate group
const VENDOR_FIELDS = new Set(['vendor_name', 'vendor_address']);

// Initialize result object
const result = { invoice: {}, vendor: {}, lineItems: [] };

// --- Invoice group (single instance) ---
// Contains both invoice-level fields and vendor fields
const invoice = findField("Default.Invoice");
if (invoice && !invoice.IsMissing && invoice.Values?.length) {
  for (const comp of invoice.Values[0]?.Components || []) {
    const key = sanitizeFieldName(comp?.FieldName);
    if (VENDOR_FIELDS.has(comp?.FieldName)) {
      result.vendor[key] = readComponent(comp);
    } else {
      result.invoice[key] = readComponent(comp);
    }
  }
}

// --- Line Items group (repeating: one entry per row) ---
const lineItems = findField("Default.Invoice>line_items");
if (lineItems && !lineItems.IsMissing && lineItems.Values?.length) {
  for (const row of lineItems.Values || []) {
    const item = {};
    for (const comp of row?.Components || []) {
      item[sanitizeFieldName(comp?.FieldName)] = readComponent(comp);
    }
    result.lineItems.push(item);
  }
}

// Remove spaces from the keys in the result object recursively
const sanitizeKeys = (obj) => {
  if (Array.isArray(obj)) {
    return obj.map(sanitizeKeys);
  } else if (obj && typeof obj === 'object') {
    return Object.fromEntries(
      Object.entries(obj).map(([key, value]) => [sanitizeFieldName(key), sanitizeKeys(value)])
    );
  }
  return obj;
};

return sanitizeKeys(result);]]></bpmn:script>
    </bpmn:scriptTask>
